# Open Alactritty
lctrl + alt + cmd - n : open -a Arc
lctrl + alt + cmd - t : open -a Alacritty
lctrl + alt + cmd + shift - t : open -n -a Alacritty
lctrl + alt + cmd - s : open -a Mail

# Switch window focus
lctrl + alt + cmd - h : yabai -m window --focus west
lctrl + alt + cmd - j : yabai -m window --focus south
lctrl + alt + cmd - k : yabai -m window --focus north
lctrl + alt + cmd - l : yabai -m window --focus east

lctrl + alt + cmd - d : yabai -m space --focus prev
lctrl + alt + cmd - b : yabai -m space --focus next

# Full Screen
# lctrl + alt + cmd - f : yabai -m window --toggle zoom-fullscreen
lctrl + alt + cmd + shift - f : yabai -m window --toggle native-fullscreen

# Restart Yabai
lctrl + alt + cmd + shift - b : yabai --restart-service

# Change split ratio

# Swap managed window
lctrl + alt + cmd + shift - k : yabai -m window --swap north
lctrl + alt + cmd + shift - h : yabai -m window --swap west
lctrl + alt + cmd + shift - j : yabai -m window --swap south
lctrl + alt + cmd + shift - l : yabai -m window --swap east

# Select desktop
lctrl + alt + cmd - g : yabai -m space --focus 1
lctrl + alt + cmd - c : yabai -m space --focus 2
lctrl + alt + cmd - r : yabai -m space --focus 3

# Send window to desktop and focus
lctrl + alt + cmd + shift - g : yabai -m window --space  1; yabai -m space --focus 1
lctrl + alt + cmd + shift - c : yabai -m window --space  2; yabai -m space --focus 2
lctrl + alt + cmd + shift - r : yabai -m window --space  3; yabai -m space --focus 3

# Create and destroy desktops
lctrl + alt + cmd - x : yabai -m space --create
lctrl + alt + cmd + shift - x : yabai -m space --destroy


# Executables
lctrl + alt + cmd - m : menubar

# Resize windows
lctrl + alt + cmd - left : yabai -m window --resize left:-50:0; yabai -m window --resize right:-50:0
lctrl + alt + cmd - right : yabai -m window --resize right:50:0; yabai -m window --resize left:50:0
